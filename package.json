{
  "name": "ojflow",
  "version": "1.0.0",
  "description": "OJ Helper Reborn in Electron",
  "author": "Your Name",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"bun run vite\" \"wait-on http://localhost:5173 && bun x electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "bun run build && electron-builder --dir",
    "dist": "bun run build && electron-builder",
    "dist:win": "bun run build && electron-builder --win",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:linux": "bun run build && electron-builder --linux",
    "test:unit": "bun test",
    "test:e2e": "playwright test"
  },
  "resolutions": {
    "entities": "6.0.0"
  },
  "dependencies": {
    "@vicons/material": "^0.13.0",
    "@vicons/utils": "^0.1.4",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "electron-store": "^8.1.0",
    "naive-ui": "^2.35.0",
    "pinia": "^2.1.7",
    "sass": "^1.69.5",
    "vfonts": "^0.0.3",
    "vue": "^3.3.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.22",
    "wait-on": "^7.1.0"
  },
  "build": {
    "appId": "com.ojflow.app",
    "productName": "OJFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "zip",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    }
  }
}
