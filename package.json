{
  "name": "ojflow",
  "version": "1.1.0",
  "description": "OJ Helper Reborn in Electron",
  "author": {
    "name": "Siborne",
    "email": "bo7785888@gmail.com"
  },
  "homepage": "https://github.com/Siborne/OJFlow",
  "repository": {
    "type": "git",
    "url": "https://github.com/Siborne/OJFlow.git",
    "directory": "electron",
    "bugs": {
      "url": "https://github.com/Siborne/OJFlow/issues"
    },
    "keywords": [
      "OJ",
      "Online Judge",
      "OJFlow",
      "OJ Helper",
      "OJ Helper Reborn",
      "OJ Helper Reborn in Electron",
      "OJ Helper Reborn in Electron for Windows",
      "OJ Helper Reborn in Electron for Mac",
      "OJ Helper Reborn in Electron for Linux",
      "OJ Helper Reborn in Electron for Windows 10",
      "OJ Helper Reborn in Electron for Linux Mint",
      "OJ Helper Reborn in Electron for Windows 11"
    ]
  },
  "license": "MIT",
  "main": "electron-dist/electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').cpSync('electron/app.config.json','electron-dist/electron/app.config.json')\"",
    "rebuild": "electron-rebuild",
    "dev": "bun run build:electron && concurrently \"bun run vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "bun run build:electron && bun run build && electron-builder --dir",
    "dist": "bun run build:electron && bun run build && electron-builder",
    "dist:win": "bun run build:electron && bun run build && electron-builder --win",
    "dist:mac": "bun run build:electron && bun run build && electron-builder --mac",
    "dist:linux": "bun run build:electron && bun run build && electron-builder --linux",
    "test:unit": "bun test tests/unit",
    "test:e2e": "playwright test tests/e2e",
    "lint": "eslint src/ electron/ shared/ tests/",
    "lint:fix": "eslint --fix src/ electron/ shared/ tests/",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss}\" \"electron/**/*.ts\" \"shared/**/*.ts\"",
    "type-check": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "overrides": {
    "entities": "6.0.0"
  },
  "dependencies": {
    "@vicons/material": "^0.13.0",
    "@vicons/utils": "^0.1.4",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "electron-store": "^8.1.0",
    "naive-ui": "^2.35.0",
    "pinia": "^2.1.7",
    "sass": "^1.69.5",
    "vfonts": "^0.0.3",
    "vue": "^3.3.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.9.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.0.0",
    "typescript": "5.2.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.22",
    "wait-on": "^7.1.0"
  },
  "build": {
    "appId": "com.ojflow.app",
    "productName": "OJFlow",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "electron/app.config.json",
      "package.json"
    ],
    "extraResources": [
      "src/assets/icon.ico",
      "src/assets/icon.icns",
      "src/assets/icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "src/assets/icon.png",
      "category": "Utility"
    }
  }
}
